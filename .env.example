# ════════════════════════════════════════════════════════════════
#  YASS: Your AI Speaking System
#  Central config. Copy to .env and fill in (or use the ⚙ panel).
#  cp .env.example .env
# ════════════════════════════════════════════════════════════════

# ── Fish Audio (TTS) ── REQUIRED ──
# Create the key at https://fish.audio, Settings, API Keys
FISH_API_KEY=

# Voice model id (empty = default voice):
FISH_VOICE_ID=a5b93aeddcc948c19ea04f0afe9d178c

# ── OpenAI ── OPTIONAL ──
# gpt-4o-mini rewrites/shortens the text before speaking. Empty = disabled.
OPENAI_API_KEY=

# ── Daemon + app HTTP port (default 3891) ──
# PORT=3891

# ── Override the .env path (non-default installs) ──
# YASS_ENV=/absolute/path/.env
