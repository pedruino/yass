{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "YASS",
  "version": "0.1.0",
  "identifier": "com.pedruino.yass",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3891",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Y.A.S.S.",
        "url": "index.html",
        "width": 800,
        "height": 820,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "visible": true,
        "focus": true,
        "center": true,
        "skipTaskbar": false,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:3891 ipc: http://ipc.localhost; media-src 'self' http://localhost:3891 blob:; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/yass-daemon"],
    "resources": {
      "../../config/personas.json": "seed/personas.json",
      "../../glossary.json": "seed/glossary.json",
      "../../hooks/speak-hook.js": "seed/speak-hook.js",
      "../dist": "dist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
